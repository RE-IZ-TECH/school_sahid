<odoo>
    <record id = "view_student_search" model="ir.ui.view">
        <field name = "name">sh.student.search</field>
        <field name = "model">sh.student</field>
        <field name = "arch" type = "xml">
            <search>
                <field name = "code"/>
                <field name = "name"/>
                <field name = "school_id"/>

                <group expand = "0" string = "Group by">
                    <filter name = "group_school"
                    string = "School"
                    context="{'group_by':'school_id'}"/>
                </group>
            </search>
        </field>
    </record>


    <record id="view_student_list" model="ir.ui.view">
        <field name="name">sh.student.list</field>
        <field name="model">sh.student</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="age"/>
                <field name="partner_id"/>
                <field name="school_id" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_student_form" model="ir.ui.view">
        <field name="name">sh.student.form</field>
        <field name="model">sh.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="partner_id"/>
                        <field name="school_id" readonly="1"/>
                    </group>
                </sheet>
                        <div class="oe_chatter">
                            <field name="message_follower_ids"/>
                            <field name="activity_ids"/>
                            <field name="message_ids"/>
                        </div>
            </form>
        </field>
    </record>

    <record id="action_students" model="ir.actions.act_window">
    <field name="name">Students</field>
    <field name="res_model">sh.student</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_student_search"/>
</record>

</odoo>