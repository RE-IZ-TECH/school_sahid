<odoo>

    <record id="view_subject_list" model="ir.ui.view">
        <field name="name">sh.subject.list</field>
        <field name="model">sh.subject</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="career_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_subject_form" model="ir.ui.view">
        <field name="name">sh.subject.form</field>
        <field name="model">sh.subject</field>
        <field name="arch" type="xml">
            <form>
                <sheet>

                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="career_id"/>
                    </group>

                    <group>
                        <field name="description"/>
                        <field name="active"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>


    <record id="action_subjects" model="ir.actions.act_window">
        <field name="name">Subjects</field>
        <field name="res_model">sh.subject</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>