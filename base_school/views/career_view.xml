<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA DE BUSQUEDA -->
    <record id="view_career_search" model="ir.ui.view">
        <field name="name">sh.career.search</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="school_id"/>

                <!-- FILTRO DE BUSQUEDA -->
                <group expand="0" string="Group by">
                    <filter name="group_school"
                    string="School"
                    context="{'group_by':'school_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- VISTA KANBAN -->
    <record id="view_career_kanban" model="ir.ui.view">
        <field name="name">sh.career.kanban</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="description"/>
                <field name="color"/>
                <field name="subjects_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div>
                                <strong>
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <field name="description"/>
                                </div>
                                <div style="margin-top:8px;">
                                    Subjects:
                                    <field name="subjects_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- VISTA DE LISTA -->
    <record id="view_career_list" model="ir.ui.view">
        <field name="name">sh.career.list</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
                <field name="school_id"/>
            </list>
        </field>
    </record>

    <!-- VISTA DE FORMULARIO -->
    <record id="view_career_form" model="ir.ui.view">
        <field name="name">sh.career.form</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <form>
                <!-- Header de botones para crear, editar borradores, etc -->
                <header/>
                <sheet>
                    <!-- Div usado para smart buttons -->
                    <div name="button_box">
                        <button type="object"
                                name="action_view_subjects"
                                class="oe_stat_button"
                                icon="fa-book">
                            <field name="subjects_count"
                                   widget="statinfo"
                                   string="Subjects"/>
                        </button>
                    </div>
                    <!-- Como buena practica añadir nombre y ID  a los div y grupos -->
                    <div class="oe_title">
                        <h2>
                            <field class="oe_inline" name="code"/> - <field class="oe_inline" name="name" placeholder="Name eg: Computer Engineering"/>
                        </h2>
                    </div>
                    <group id="career_group_general">
                        <group id="group_general_one">
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                        <group id="group_general_two">
                            <field name="school_id" readonly="1"/>
                        </group>
                    </group>
                    <group id="career_group_subjects">
                        <field name="subjects_ids"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_careers" model="ir.actions.act_window">
        <field name="name">Careers</field>
        <field name="res_model">sh.career</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_career_search"/>
    </record>

</odoo>