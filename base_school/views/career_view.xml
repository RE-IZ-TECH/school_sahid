<odoo>

    <record id="view_career_search" model="ir.ui.view">
        <field name="name">sh.career.search</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <search>

                <field name="code"/>
                <field name="name"/>
                <field name="school_id"/>

                <group expand="0" string="Group By">
                    <filter name="group_school"
                            string="School"
                            context="{'group_by':'school_id'}"/>
                </group>

            </search>
        </field>
    </record>


    <record id="view_career_list" model="ir.ui.view">
        <field name="name">sh.career.list</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
                <field name="school_id"/>
            </list>
        </field>
    </record>


    <record id="view_career_form" model="ir.ui.view">
        <field name="name">sh.career.form</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_view_subjects"
                                class="oe_stat_button"
                                icon="fa-book">
                            <field name="subjects_count"
                                   widget="statinfo"
                                   string="Subjects"/>
                        </button>
                    </div>

                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                        <field name="school_id" readonly="1"/>
                        <field name="color" widget="color_picker"/>
                    </group>

                    <group>
                        <field name="subjects_ids"/>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
</div>
            </form>
        </field>
    </record>


    <record id="view_career_kanban" model="ir.ui.view">
        <field name="name">sh.career.kanban</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <kanban create="true" default_group_by="">
                <field name="name"/>
                <field name="description"/>
                <field name="color"/>
                <field name="subjects_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_primary_left">
                                <strong>
                                    <field name="name"/>
                                </strong>
                                <div>
                                    <field name="description"/>
                                </div>
                                <div style="margin-top:8px;">
                                    Subjects:
                                    <field name="subjects_count"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="action_careers" model="ir.actions.act_window">
        <field name="name">Careers</field>
        <field name="res_model">sh.career</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_career_search"/>
    </record>


</odoo>