<odoo>

    <record id="view_career_list" model="ir.ui.view">
        <field name="name">sh.career.list</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_career_form" model="ir.ui.view">
        <field name="name">sh.career.form</field>
        <field name="model">sh.career</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>

                    <group>
                        <field name="subjects_ids"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_careers" model="ir.actions.act_window">
        <field name="name">Careers</field>
        <field name="res_model">sh.career</field>
        <field name="view_mode">list,form</field>
</record>

</odoo>