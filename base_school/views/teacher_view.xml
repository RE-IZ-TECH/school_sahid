<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA DE BUSQUEDA -->
    <record id="view_teacher_search" model="ir.ui.view">
        <field name="name">sh.teacher.search</field>
        <field name="model">sh.teacher</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="school_id"/>

                <!-- FILTRO DE BUSQUEDA -->
                <group expand="0" string="Group by">
                    <filter name="group_school"
                    string="School"
                    context="{'group_by':'school_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- VISTA DE LISTA -->
    <record id="view_teacher_list" model="ir.ui.view">
        <field name="name">sh.teacher.list</field>
        <field name="model">sh.teacher</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="age"/>
                <field name="partner_id"/>
                <field name="school_id" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- VISTA DE FORMULARIO -->
    <record id="view_teacher_form" model="ir.ui.view">
        <field name="name">sh.teacher.form</field>
        <field name="model">sh.teacher</field>
        <field name="arch" type="xml">
            <form>
                <!-- Header de botones para crear, editar borradores, etc -->
                <header/>
                <sheet>
                    <!-- Div usado para smart buttons -->
                    <div/>
                    <!-- Como buena practica añadir nombre y ID  a los div y grupos -->
                    <div class="oe_title">
                        <h2>
                            <field class="oe_inline" name="code"/> - <field class="oe_inline" name="name" placeholder="Name eg: Josué Sahid Hernández Díaz"/>
                        </h2>
                    </div>
                    <group id="teacher_group_general">
                        <group id="group_general_one">
                            <field name="age" widget="integer"/>
                        </group>
                        <group id="group_general_two">
                            <field name="partner_id"/>
                            <field name="school_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_teachers" model="ir.actions.act_window">
        <field name="name">Teachers</field>
        <field name="res_model">sh.teacher</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_teacher_search"/>
    </record>

</odoo>